<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Deep-link scheme used by Supabase auth: OAuth callbacks and the links
	     in confirmation / password-recovery emails all redirect here. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.kevinhuang.eigenform.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>eigenform</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
